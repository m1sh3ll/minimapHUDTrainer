<Window x:Class="MiniMapHudTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniMap HUD Trainer"
        Height="800"
        Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#111111">

      <Grid Margin="20">

            <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- INTERVAL -->
            <StackPanel Orientation="Vertical"
                    Margin="0,0,0,15">

                  <TextBlock Text="Alert Interval (seconds)"
                       Foreground="White"
                       FontSize="18"
                       Margin="0,0,0,10"/>

                  <StackPanel Orientation="Horizontal">

                        <Slider x:Name="sliderInterval"
                        Width="300"
                        Minimum="3"
                        Maximum="60"
                        Value="15"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="sliderInterval_ValueChanged"/>

                        <TextBlock x:Name="txtSliderValue"
                           Text="15"
                           Foreground="White"
                           FontSize="22"
                           Width="60"
                           Margin="15,0,0,0"
                           VerticalAlignment="Center"/>
                  </StackPanel>
            </StackPanel>

            <!-- IMAGE SELECT -->
            <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,15">

                  <TextBlock Text="Minimap Image:"
                       Foreground="White"
                       FontSize="18"
                       Width="160"
                       VerticalAlignment="Center"/>

                  <ComboBox x:Name="cmbImages"
                      Width="300"
                      Height="35"
                      FontSize="16"
                      SelectionChanged="cmbImages_SelectionChanged"/>
            </StackPanel>

            <!-- VOICE SELECT -->
            <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

                  <TextBlock Text="Voice Clip:"
                       Foreground="White"
                       FontSize="18"
                       Width="160"
                       VerticalAlignment="Center"/>

                  <ComboBox x:Name="cmbVoices"
                      Width="236"
                      Height="35"
                      FontSize="16"/>

                  <Button x:Name="btnStart"
                    Content="START"
                    Width="120"
                    Height="45"
                    FontSize="18"
                    Margin="20,0,0,0"
                    Click="btnStart_Click"/>

                  <Button x:Name="btnStop"
                    Content="STOP"
                    Width="120"
                    Height="45"
                    FontSize="18"
                    Margin="10,0,0,0"
                    Click="btnStop_Click"/>
            </StackPanel>

            <!-- DISPLAY AREA -->
            <Border Grid.Row="3"
                BorderBrush="#444444"
                BorderThickness="2"
                Background="#000000" Margin="80,26,80,25">

                  <Grid VerticalAlignment="Bottom">

                        <!-- MINIMAP IMAGE -->
                        <Image x:Name="imgMiniMap"
                       Visibility="Hidden"
                       Stretch="Uniform"/>

                        <!-- LARGE HUD TEXT -->
                        <TextBlock x:Name="txtHudAlert"
                           Text=""
                           Foreground="White"
                           FontSize="80"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Hidden"/>

                  </Grid>

            </Border>

      </Grid>
</Window>